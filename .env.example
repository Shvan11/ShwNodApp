# =============================================================================
# Shwan Orthodontics Management System — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in real values. NEVER commit the real .env.
# For WSL-specific dev overrides, use `.env.development` (also gitignored).
#
# Legend:  [required]  must be set or the app will not start / feature breaks
#          [optional]  feature-specific; leave blank to disable that feature
# =============================================================================


# -----------------------------------------------------------------------------
# Server & Runtime  [required]
# -----------------------------------------------------------------------------
PORT=3001                                # 3001 dev, 3000 prod
NODE_ENV=development                     # development | production
MACHINE_PATH=C:                          # Root for patient images / X-rays
TZ=Asia/Baghdad                          # Clinic wall-clock zone — pins date handling host-independently (esp. a UTC Linux/cloud server)
PUBLIC_URL=https://remote.example.com    # Public-facing URL for OAuth redirects
QR_HOST_URL=https://clinic.local         # Host embedded in QR codes

# Override platform auto-detection (rarely needed): 'windows' or 'wsl'
# PLATFORM_TYPE=

# Carestream imaging export executable (Windows only)
# CS_EXPORT="C:\\Program Files (x86)\\Carestream\\CSDML\\export_ps.exe "


# -----------------------------------------------------------------------------
# Database — PostgreSQL  [required]
# -----------------------------------------------------------------------------
# Boot fails unless the PG connection is set: either DATABASE_URL, OR the full
# discrete PG_HOST / PG_DATABASE / PG_USER block (PG_PORT/PG_PASSWORD optional).
# Per-machine — use .env.development for WSL overrides. Use 127.0.0.1 on
# Windows-native (prod); from a WSL dev box point at the Windows host gateway IP
# (the WSL NAT gateway 172.20.0.1 drops intermittently and kills the CDC sinks).
PG_HOST=localhost                        # 127.0.0.1 on Windows-native (prod)
PG_PORT=5432
PG_DATABASE=shwan                        # code default if unset: shwan_test
PG_USER=shwan_app
PG_PASSWORD=change-me
# Alternative to the discrete PG_* block above (takes precedence if set):
# DATABASE_URL=postgresql://shwan_app:change-me@localhost:5432/shwan
#
# pg_dump binary for the Settings → Database Backup download. Optional: defaults to
# resolving `pg_dump` on PATH (fine on Linux/WSL). On Windows-native (prod) set it to
# the PostgreSQL install bin. The pg_dump version must be >= the server's PG major version.
# PG_DUMP_PATH=C:\Program Files\PostgreSQL\18\bin\pg_dump.exe


# -----------------------------------------------------------------------------
# Database — SQL Server (legacy)  [optional — Dolphin sink only, NOT used at boot]
# -----------------------------------------------------------------------------
# The Postgres cutover is complete. These feed only the temporary Dolphin sink
# (DOLPHIN_SYNC_ENABLED, see CDC section) + one-off migration tooling. Leave
# blank/as-is unless that sink is on; delete when the Dolphin sink is removed.
DB_SERVER=Clinic
DB_INSTANCE=DOLPHIN
DB_DATABASE=ShwanNew
DB_USER=Staff
DB_PASSWORD=change-me


# -----------------------------------------------------------------------------
# Authentication & Sessions  [required]
# -----------------------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required — boot fails if unset. No fallback in source.
SESSION_SECRET=replace-with-64-hex-chars
# Default-on. Set to the literal string 'false' to disable auth (dev only).
# Any other value is rejected in production to catch env typos.
AUTHENTICATION_ENABLED=true

# Separate secret for the patient/portal session cookie (independent of staff)
PORTAL_SESSION_SECRET=replace-with-64-hex-chars

# Optional — HMAC secret for the CSRF double-submit token (audit H2). Leave unset
# to reuse SESSION_SECRET (recommended). Set a dedicated value only if you want
# CSRF tokens to rotate independently of the session secret.
# CSRF_SECRET=replace-with-64-hex-chars


# -----------------------------------------------------------------------------
# Frontend (Vite)  [required for dev]
# -----------------------------------------------------------------------------
VITE_DEV_PORT=5173                       # Vite dev port (5273 on the WSL dev box, via .env.development)
VITE_API_URL=http://localhost:3001       # Express backend URL (leave blank in prod for auto-detect)


# -----------------------------------------------------------------------------
# Logging  [optional — sane defaults]
# -----------------------------------------------------------------------------
LOG_LEVEL=info                           # error | warn | info | debug
# Comma-separated category filter, e.g. "sync,messaging"
# LOG_CATEGORIES=
# LOG_STATE_EVENTS=false                 # Verbose state-machine event logging


# -----------------------------------------------------------------------------
# WhatsApp (whatsapp-web.js)  [optional]
# -----------------------------------------------------------------------------
# false in dev (Linux SIGKILL can corrupt the Web session); true in prod
WHATSAPP_AUTO_INIT=true


# -----------------------------------------------------------------------------
# Telegram  [optional]
# -----------------------------------------------------------------------------
TELEGRAM_TOKEN=                          # Bot API token from @BotFather
TELEGRAM_CHAT_ID=                        # Target chat / group ID
TELEGRAM_API_ID=                         # MTProto app api_id (my.telegram.org) — required for GramJS document send
TELEGRAM_API_HASH=                       # MTProto app api_hash (my.telegram.org)

# GramJS MTProto session string (generate with utils/setup/telegram-session-generator.js)
# GRAM_SESSION=


# -----------------------------------------------------------------------------
# Twilio SMS  [optional]
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NAME="Shwan Ortho"


# -----------------------------------------------------------------------------
# Google OAuth  [optional — required for Google Drive / Calendar features]
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# Google Drive (Aligner PDF uploads)  [optional]
# -----------------------------------------------------------------------------
# Reuses GOOGLE_CLIENT_ID/SECRET by default. Uncomment to use separate credentials.
# GOOGLE_DRIVE_CLIENT_ID=
# GOOGLE_DRIVE_CLIENT_SECRET=
# Defaults to http://localhost:${PORT}/api/admin/google-drive/callback
# GOOGLE_DRIVE_REDIRECT_URI=

# Required for Drive uploads to work
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=


# -----------------------------------------------------------------------------
# WebCeph (AI X-ray analysis)  [optional]
# -----------------------------------------------------------------------------
WEBCEPH_PARTNER_API_KEY=
WEBCEPH_USER_EMAIL=
WEBCEPH_USER_API_PASSWORD=
WEBCEPH_API_BASE_URL=https://api.webceph.com


# -----------------------------------------------------------------------------
# LocalSend — share patient files/images to LAN devices  [optional]
# -----------------------------------------------------------------------------
# The server acts as a LocalSend SENDER: it discovers receivers over UDP multicast
# and uploads files straight to the chosen device (which shows its native Accept
# prompt). Off by default. Requires LAN multicast — works on the Windows Server in
# prod; in WSL2 dev use the picker's "Add by IP". See CLAUDE.md.
LOCALSEND_ENABLED=false                   # feature on/off (opt-in)
LOCALSEND_PORT=53317                      # LocalSend default UDP/TCP port
LOCALSEND_ALIAS=Shwan Clinic Server       # name shown on receiver devices
LOCALSEND_MULTICAST=224.0.0.167           # LocalSend default multicast group


# -----------------------------------------------------------------------------
# Gemini AI (Stand item scanning)  [optional]
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
# Override model. Default: gemini-3-flash-preview. Stable fallback: gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash


# -----------------------------------------------------------------------------
# Unified CDC — forward sync (one change feed → the single Supabase database)  [optional]
# -----------------------------------------------------------------------------
# ONE unified Supabase database = a raw 1:1 mirror of this Postgres (sink 'failover'). It is the
# aligner portal's future serving source. The curated snake_case portal projection + reverse-sync
# path were retired. See CLAUDE.md › Sync (unified CDC).
#
# The mirror is reached over the Supabase session pooler (port 5432). Keep it RLS-locked /
# server-side only until the portal is rewritten to read it via RLS/views.
SUPABASE_FAILOVER_DB_URL=                # postgresql://...pooler.supabase.com:5432/postgres?sslmode=require
# Supabase admin/owner (the `postgres` role) — same credential as SUPABASE_FAILOVER_DB_URL; the highest
# privilege the project exposes (true superuser `supabase_admin` is not user-accessible). Used for DDL /
# CREATE ROLE (incl. mirror_rw). Optional duplicate-for-clarity of the owner creds.
SUPABASE_SUPERUSER_USER=                 # e.g. postgres.<projectref>
SUPABASE_SUPERUSER_PASSWORD=
# Read-only web role on the Supabase mirror (mirror_rw): SELECT everything (LOGIN BYPASSRLS), write ONLY the
# reverse set (table GRANTs). For a future web app. Create via migrations/supabase/mirror-grants.sql + a
# `CREATE ROLE mirror_rw LOGIN BYPASSRLS PASSWORD '…'`. Connect via the pooler as mirror_rw.<projectref>.
SUPABASE_MIRROR_RW_USER=                 # e.g. mirror_rw.<projectref>
SUPABASE_MIRROR_RW_PASSWORD=
SUPABASE_MIRROR_RW_URL=                  # postgresql://mirror_rw.<ref>:<pw>@...pooler.supabase.com:5432/postgres?sslmode=require
FAILOVER_SYNC_ENABLED=false              # mirror sink on/off (opt-in)
FAILOVER_SYNC_INTERVAL_MS=5000           # mirror drain cycle
FAILOVER_SYNC_BATCH_SIZE=200             # mirror rows per cycle
FAILOVER_SYNC_MAX_BACKLOG=100000         # anti-bloat breaker: above this, capture auto-disables + flags stale

# Reverse sync (TWO-WAY): Supabase → local — the symmetric mirror image of the forward failover sink.
# Drains a change_log that lives ON Supabase (written by genuine web/portal edits via the Supabase
# cdc_capture_remote trigger) and applies each change back to local through a DEDICATED max-2 pool,
# so it can't contend with the app's 10-conn pool. Whole-row last-write-wins by updated_at; deletes
# propagate. Reuses SUPABASE_FAILOVER_DB_URL above. OFF by default. Requires the Supabase reverse
# infra (migrations/supabase/reverse-cdc.sql) + the local version-guard migration applied first, and
# the forward-write code (origin GUC) running BEFORE the Supabase version trigger exists.
# Kill switch without restart — its control row lives on SUPABASE, so run THERE:
#   UPDATE cdc_sink_control SET enabled=false WHERE sink='reverse';
REVERSE_SYNC_ENABLED=false               # reverse sink on/off (opt-in)
REVERSE_SYNC_INTERVAL_MS=10000           # reverse drain cycle
REVERSE_SYNC_BATCH_SIZE=100              # reverse rows per cycle
REVERSE_SYNC_MAX_BACKLOG=100000          # reverse anti-bloat breaker: above this, capture auto-disables + flags stale

# Dolphin sink (TEMPORARY): PostgreSQL → legacy Dolphin Imaging SQL Server (DolphinPlatform.dbo.*).
# Mirrors timepoint/image rows the photo editor writes so Dolphin "sees" app-cropped photos until
# the native pipeline is trusted. DB rows only (files already land in working/). Reuses the DB_*
# (SQL Server) connection above. Off by default; delete this block when the sink is removed.
# Kill switch without restart: UPDATE cdc_sink_control SET enabled=false WHERE sink='dolphin';
DOLPHIN_SYNC_ENABLED=false               # dolphin sink on/off (opt-in)
DOLPHIN_SYNC_INTERVAL_MS=5000            # dolphin drain cycle
DOLPHIN_SYNC_BATCH_SIZE=100              # dolphin rows per cycle
DOLPHIN_SYNC_MAX_BACKLOG=100000          # dolphin anti-bloat breaker: above this, capture auto-disables + flags stale

# -----------------------------------------------------------------------------
# External aligner portal — auth bridge (POST /api/aligner-portal/token)  [optional]
# -----------------------------------------------------------------------------
# The aligner-portal-external app reads the raw Supabase mirror under RLS. It cannot use the
# anon key alone (the mirror holds the whole clinic DB), so the main app verifies the portal's
# Cloudflare-Access JWT and mints a short-lived Supabase JWT carrying a `dr_id` claim that RLS
# keys off. Leave blank to disable the endpoint (it 500s with a clear message if called).
SUPABASE_JWT_SECRET=                     # the failover Supabase project's JWT secret (HS256 signing key)
CF_ACCESS_TEAM_DOMAIN=                    # e.g. myteam.cloudflareaccess.com (issuer + JWKS source)
CF_ACCESS_AUD=                            # the Cloudflare Access application AUD tag (portal app)
PORTAL_ALLOWED_ORIGIN=                    # the portal's Cloudflare Pages origin, for CORS (e.g. https://portal.example.com)


# -----------------------------------------------------------------------------
# Windows Service (production only)  [optional]
# -----------------------------------------------------------------------------
# Required when installing as a Windows service so WhatsApp/Puppeteer can launch
# Chrome under a user account that has Chrome installed.
SERVICE_ACCOUNT=.\\Administrator
SERVICE_PASSWORD=
