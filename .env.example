# =============================================================================
# Shwan Orthodontics Management System — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in real values. NEVER commit the real .env.
# For WSL-specific dev overrides, use `.env.development` (also gitignored).
#
# Legend:  [required]  must be set or the app will not start / feature breaks
#          [optional]  feature-specific; leave blank to disable that feature
# =============================================================================


# -----------------------------------------------------------------------------
# Server & Runtime  [required]
# -----------------------------------------------------------------------------
PORT=3001                                # 3001 dev, 3000 prod
NODE_ENV=development                     # development | production
MACHINE_PATH=C:                          # Root for patient images / X-rays
PUBLIC_URL=https://remote.example.com    # Public-facing URL for OAuth redirects
QR_HOST_URL=https://clinic.local         # Host embedded in QR codes

# Override platform auto-detection (rarely needed): 'windows' or 'wsl'
# PLATFORM_TYPE=

# Carestream imaging export executable (Windows only)
# CS_EXPORT="C:\\Program Files (x86)\\Carestream\\CSDML\\export_ps.exe "


# -----------------------------------------------------------------------------
# Database — SQL Server  [required]
# -----------------------------------------------------------------------------
DB_SERVER=Clinic
DB_INSTANCE=DOLPHIN
DB_DATABASE=ShwanNew
DB_USER=Staff
DB_PASSWORD=change-me


# -----------------------------------------------------------------------------
# Authentication & Sessions  [required]
# -----------------------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required — boot fails if unset. No fallback in source.
SESSION_SECRET=replace-with-64-hex-chars
# Default-on. Set to the literal string 'false' to disable auth (dev only).
# Any other value is rejected in production to catch env typos.
AUTHENTICATION_ENABLED=true

# Separate secret for the patient/portal session cookie (independent of staff)
PORTAL_SESSION_SECRET=replace-with-64-hex-chars


# -----------------------------------------------------------------------------
# Frontend (Vite)  [required for dev]
# -----------------------------------------------------------------------------
VITE_DEV_PORT=5173                       # Vite dev server port
VITE_API_URL=http://localhost:3001       # Express backend URL (leave blank in prod for auto-detect)
VITE_WS_URL=ws://localhost:3001          # WebSocket URL (leave blank in prod for auto-detect)


# -----------------------------------------------------------------------------
# Logging  [optional — sane defaults]
# -----------------------------------------------------------------------------
LOG_LEVEL=info                           # error | warn | info | debug
# Comma-separated category filter, e.g. "websocket,sync,messaging"
# LOG_CATEGORIES=
# LOG_STATE_EVENTS=false                 # Verbose state-machine event logging


# -----------------------------------------------------------------------------
# WhatsApp (whatsapp-web.js)  [optional]
# -----------------------------------------------------------------------------
# false in dev (Linux SIGKILL can corrupt the Web session); true in prod
WHATSAPP_AUTO_INIT=true


# -----------------------------------------------------------------------------
# Telegram  [optional]
# -----------------------------------------------------------------------------
TELEGRAM_TOKEN=                          # Bot API token from @BotFather
TELEGRAM_CHAT_ID=                        # Target chat / group ID

# GramJS MTProto session string (generate with utils/setup/telegram-session-generator.js)
# GRAM_SESSION=


# -----------------------------------------------------------------------------
# Twilio SMS  [optional]
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NAME="Shwan Ortho"


# -----------------------------------------------------------------------------
# Google OAuth  [optional — required for Google Drive / Calendar features]
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# Google Drive (Aligner PDF uploads)  [optional]
# -----------------------------------------------------------------------------
# Reuses GOOGLE_CLIENT_ID/SECRET by default. Uncomment to use separate credentials.
# GOOGLE_DRIVE_CLIENT_ID=
# GOOGLE_DRIVE_CLIENT_SECRET=
# Defaults to http://localhost:${PORT}/api/admin/google-drive/callback
# GOOGLE_DRIVE_REDIRECT_URI=

# Required for Drive uploads to work
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=


# -----------------------------------------------------------------------------
# WebCeph (AI X-ray analysis)  [optional]
# -----------------------------------------------------------------------------
WEBCEPH_PARTNER_API_KEY=
WEBCEPH_USER_EMAIL=
WEBCEPH_USER_API_PASSWORD=
WEBCEPH_API_BASE_URL=https://api.webceph.com


# -----------------------------------------------------------------------------
# Gemini AI (Stand item scanning)  [optional]
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
# Override model. Default: gemini-3-flash-preview. Stable fallback: gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash


# -----------------------------------------------------------------------------
# Supabase Sync  [optional — required for cross-device sync]
# -----------------------------------------------------------------------------
# Master switch for the whole sync subsystem (forward enqueue + queue processor +
# reverse poller + webhook). Leave false to fully disable (e.g. sandbox); set true
# in production. When false, write paths skip the SyncQueue enqueue entirely.
SYNC_ENABLED=false
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_WEBHOOK_SECRET=                 # HMAC secret for inbound webhook auth


# -----------------------------------------------------------------------------
# Reverse Sync (Supabase → SQL Server)  [optional]
# -----------------------------------------------------------------------------
# See docs/REVERSE_SYNC_CONFIGURATION.md
REVERSE_SYNC_ENABLED=true
REVERSE_SYNC_INTERVAL_MINUTES=60
REVERSE_SYNC_LOOKBACK_HOURS=24
REVERSE_SYNC_MAX_RECORDS=500


# -----------------------------------------------------------------------------
# Windows Service (production only)  [optional]
# -----------------------------------------------------------------------------
# Required when installing as a Windows service so WhatsApp/Puppeteer can launch
# Chrome under a user account that has Chrome installed.
SERVICE_ACCOUNT=.\\Administrator
SERVICE_PASSWORD=
